// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MODELS
// ============================================================================

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  emailVerified      DateTime?
  password           String    @db.VarChar(255)
  phone              String?
  company            String?
  role               Role      @default(CUSTOMER)
  status             UserStatus @default(ACTIVE)

  // Relations
  orders             Order[]
  quotes             Quote[]
  addresses          Address[]
  payments           Payment[]
  accounts           Account[]
  sessions           Session[]

  // Audit
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
}

enum Role {
  ADMIN
  CUSTOMER
  VENDOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================================================
// AUTHENTICATION MODELS
// ============================================================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refreshToken       String?  @db.Text
  accessToken        String?  @db.Text
  expiresAt          Int?
  tokenType          String?
  scope              String?
  idToken            String?  @db.Text
  sessionState       String?

  user               User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id                 String    @id @default(cuid())
  sessionToken       String    @unique
  userId             String
  expires            DateTime
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier         String
  token              String    @unique
  expires            DateTime

  @@unique([identifier, token])
}

// ============================================================================
// PRODUCT MODELS
// ============================================================================

model Category {
  id                 String    @id @default(cuid())
  name               String    @unique
  slug               String    @unique
  description        String?   @db.Text
  image              String?
  isActive           Boolean   @default(true)

  products           Product[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([isActive])
}

model Product {
  id                 String    @id @default(cuid())
  name               String
  description        String    @db.Text
  sku                String    @unique
  price              Decimal   @db.Decimal(10, 2)
  basePrice          Decimal   @db.Decimal(10, 2)
  category           Category  @relation(fields: [categoryId], references: [id])
  categoryId         String

  stock              Int       @default(0)
  isInStock          Boolean   @default(true)

  images             ProductImage[]
  attributes         ProductAttribute[]
  variantGroups      VariantGroup[]
  customizationOptions CustomizationOption[]

  cartItems          CartItem[]
  orderItems         OrderItem[]
  quoteItems         QuoteItem[]

  isActive           Boolean   @default(true)
  isFeatured         Boolean   @default(false)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([categoryId])
  @@index([sku])
  @@index([isActive])
  @@index([isFeatured])
}

model ProductImage {
  id                 String    @id @default(cuid())
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId          String
  url                String
  alt                String?
  displayOrder       Int       @default(0)

  createdAt          DateTime  @default(now())

  @@index([productId])
}

model ProductAttribute {
  id                 String    @id @default(cuid())
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId          String
  name               String
  value              String

  createdAt          DateTime  @default(now())

  @@index([productId])
}

model VariantGroup {
  id                 String    @id @default(cuid())
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId          String
  name               String
  options            String[]

  createdAt          DateTime  @default(now())

  @@index([productId])
}

model CustomizationOption {
  id                 String    @id @default(cuid())
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId          String
  name               String
  type               String
  isRequired         Boolean   @default(false)

  createdAt          DateTime  @default(now())

  @@index([productId])
}

// ============================================================================
// CART MODELS
// ============================================================================

model Cart {
  id                 String    @id @default(cuid())
  sessionId          String    @unique
  items              CartItem[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model CartItem {
  id                 String    @id @default(cuid())
  cart               Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId             String
  product            Product   @relation(fields: [productId], references: [id])
  productId          String
  quantity           Int
  customDetails      String?   @db.Text

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([cartId])
  @@index([productId])
}

// ============================================================================
// ORDER MODELS
// ============================================================================

model Order {
  id                 String    @id @default(cuid())
  orderNumber        String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String

  items              OrderItem[]
  total              Decimal   @db.Decimal(12, 2)
  subtotal           Decimal   @db.Decimal(12, 2)
  tax                Decimal   @db.Decimal(10, 2)
  shipping           Decimal   @db.Decimal(10, 2)
  discount           Decimal   @db.Decimal(10, 2) @default(0)

  status             OrderStatus @default(PENDING)
  shippingAddress    Address?  @relation("OrderShipping", fields: [shippingAddressId], references: [id])
  shippingAddressId  String?
  billingAddress     Address?  @relation("OrderBilling", fields: [billingAddressId], references: [id])
  billingAddressId   String?

  payment            Payment?  @relation(fields: [paymentId], references: [id])
  paymentId          String?

  trackingNumber     String?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  notes              String?   @db.Text

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id                 String    @id @default(cuid())
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId            String
  product            Product   @relation(fields: [productId], references: [id])
  productId          String
  quantity           Int
  price              Decimal   @db.Decimal(10, 2)
  customDetails      String?   @db.Text

  createdAt          DateTime  @default(now())

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ============================================================================
// QUOTE MODELS
// ============================================================================

model Quote {
  id                 String    @id @default(cuid())
  quoteNumber        String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String

  items              QuoteItem[]
  total              Decimal   @db.Decimal(12, 2)

  status             QuoteStatus @default(PENDING)
  expiresAt          DateTime

  convertedToOrder   Order?
  convertedToOrderId String?

  customDetails      String?   @db.Text

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model QuoteItem {
  id                 String    @id @default(cuid())
  quote              Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId            String
  product            Product   @relation(fields: [productId], references: [id])
  productId          String
  quantity           Int
  price              Decimal   @db.Decimal(10, 2)
  customDetails      String?   @db.Text

  createdAt          DateTime  @default(now())

  @@index([quoteId])
  @@index([productId])
}

enum QuoteStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

// ============================================================================
// PAYMENT MODELS
// ============================================================================

model Payment {
  id                 String    @id @default(cuid())
  orders             Order[]
  amount             Decimal   @db.Decimal(12, 2)
  status             PaymentStatus @default(PENDING)

  provider           PaymentProvider
  transactionId      String?   @unique
  reference          String?   @unique

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String

  metadata           Json?
  failureReason      String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([transactionId])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESSFUL
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  STRIPE
}

// ============================================================================
// ADDRESS MODELS
// ============================================================================

model Address {
  id                 String    @id @default(cuid())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String

  type               AddressType
  firstName          String
  lastName           String
  street1            String
  street2            String?
  city               String
  state              String
  postalCode         String
  country            String
  phone              String?

  shippingOrders     Order[]   @relation("OrderShipping")
  billingOrders      Order[]   @relation("OrderBilling")

  isDefault          Boolean   @default(false)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}
